PORT=5000
MONGODB_URI=mongodb://localhost:27017/jeevanconnect
JWT_SECRET=replace_with_strong_secret
GOOGLE_MAPS_API_KEY=replace_with_google_maps_key

# Twilio for SMS (optional)
TWILIO_ACCOUNT_SID=replace_with_twilio_sid
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_SID=replace_with_twilio_verify_service_sid

# Custom verification service (optional)
VERIFY_SERVICE_URL=https://your-verify-service.com/api/send-otp
VERIFY_SERVICE_API_KEY=replace_with_verify_service_api_key
VERIFY_SERVICE_AUTH_HEADER=Authorization
